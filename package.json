{
  "dependencies": {
    "@marp-team/marp-cli": "^4.0.4"
  },
  "devDependencies": {
    "hugo-installer": "^4.0.1"
  },
  "otherDependencies": {
    "hugo": "0.147.1"
  },
  "scripts": {
    "build": "webpack",
    "clean": "rm -rf resources/_gen",
    "postinstall": "hugo-installer --version otherDependencies.hugo --extended",
    "serve": "bun run clean && hugo server -D"
  },
  "packageManager": "bun@1.3.11"
}
